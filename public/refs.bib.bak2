@article{jpcm_21_084207_2009,
  author = {Biswas, Parthapratim and Tafen, D N and Inam, F and Cai, Bin and Drabold, D A},
  title = {Materials modeling by design: applications to amorphous solids},
  journal = {J. Phys.: Condens. Matter},
  year = {2009},
  volume = {21},
  number = {8},
  pages = {084207},
  doi = {10.1088/0953-8984/21/8/084207},
  issn = {0953-8984},
  abstract = {In this paper, we review a host of methods used to model amorphous materials. We particularly describe methods which impose constraints on the models to ensure that the final model meets a priori requirements (on structure, topology, chemical order, etc). In particular, we review work based on quench from the melt simulations, the {\textquoteright}decorate and relax{\textquoteright} method, which is shown to be a reliable scheme for forming models of certain binary glasses. A {\textquoteright}building block{\textquoteright} approach is also suggested and yields a pleading model for GeSe 1.5 . We also report on the nature of vulcanization in an Se network cross-linked by As, and indicate how introducing H into an a-Si network develops into a-Si:H. We also discuss explicitly constrained methods including reverse Monte Carlo (RMC) and a novel method called {\textquoteright}Experimentally Constrained Molecular Relaxation{\textquoteright}. The latter merges the power of ab initio simulation with the ability to impose external information associated with RMC.}
}

