@article{jes_141_L127_1994,
  author = {Orel, B. and Lavrenčič‐Štangar, U. and Kalcher, K.},
  title = {Electrochemical and Structural Properties of {SnO$_{2}$} and Sb : {SnO$_{2}$} Transparent Electrodes with Mixed Electronically Conductive and Ion‐Storage Characteristics},
  journal = {J. Electrochem. Soc.},
  year = {1994},
  volume = {141},
  number = {9},
  pages = {L127-L130},
  doi = {10.1149/1.2055177},
  issn = {0013-4651},
  abstract = {Thin and Sb-doped films have been prepared from aqueous colloidal solutions containing and precursors by the dip-coating technique. The films are characterized as small grains (40 to 70 {\r A}) and exhibit the ability to uptake reversibly Li+ and H+ ions from solutions of (0.1 M) in acetonitrile (AN) or water, (0.1 M) and (0.001 to 0.01 M). It was found that Sb-doped (7 a/o Sb) films thicker than 100 nm exhibit about three times greater (de)inserted charges as compared to the undoped films. With regard to the amount of (de)inserted charge (up to 8 mC/cm2), Sb-doped films are suitable for mixed electronically conductive, ion-storage electrodes in electrochromic devices.}
}

