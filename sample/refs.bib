@article {i_1_400_1995,
	title = {Physical and electrochemical properties of Li-intercalated Sn oxide films made by sputtering},
	journal = {Ionics},
	volume = {1},
	year = {1995},
	month = {Sep},
	pages = {400{\textendash}405},
	abstract = {Sn oxide films were made by reactive rf magnetron sputtering under conditions that led to both electronic and ionic conductivity. The film structure was studied by X-ray diffraction and Atomic Force Microscopy (AFM). Li+ intercalation produced electrochromism with coloration efficiency peaked in the infrared. Cyclic voltammograms taken at different sweep rates were interpreted in terms of a unique structural parameter related to the fractal dimension of a self-affine surface relief and in excellent agreement with the fractal dimension as obtained with AFM. M{\"o}ssbauer spectroscopy was used to determine the valence state of the Sn-atoms; a change from Sn4+ to Sn2+ was detected after electrochemical intercalation of Li+.},
	issn = {1862-0760},
	doi = {10.1007/BF02375283},
	author = {Isidorsson, J. and Str{\o}mme, M. and G{\r a}hlin, R. and Niklasson, G. A. and Granqvist, C. G. and H{\"a}ggstr{\"o}m, L.}
