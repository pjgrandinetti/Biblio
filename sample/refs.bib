	pages = {3407-3411},
	chapter = {3407},
	abstract = {Quadrupole splitting of the deuteron magnetic resonance was measured in single crystals of solid D20 at -lo{\textdegree}C. For deuterons on the hexagonal crystal axis, eQqt/h equaled 213.2{\textpm}0.S kc/sec, and 11111 was equal to 0.100{\textpm}0.OO2. For the other deuterons, eQq2/h was found to be equal to 216.4{\textpm}1.0 kc/sec. No change in the line separations was observed at a temperature of -70{\textdegree}C. No evidence was found for hindered rotation of the D20 molecules nor for intermolecular deuteron transfer at -lo{\textdegree}C. Lower limits to the barriers hindering these motions were estimated; these limits permit estimates to be made of hydrogen-bond energies. The coupling constants in the solid are about 30\% less than those reported for the free molecule. Most of this decrease must be ascribed to electronic structural changes brought about as a result of hydrogen- bond formation.},
